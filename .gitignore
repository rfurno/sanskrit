# =============================================================================
# Sanskrit Workspace - Root .gitignore
# =============================================================================
# This is the canonical .gitignore for the repository.
# Place it at the git repo root (the folder containing .git/).

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Virtual Environments (anywhere in the repo)
# -----------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/
conda-meta/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs, Cache & Temp
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# SanskritMantraPronunciationCoach specific ignores
# These paths are relative to the repository root (everything is flat here now).
# -----------------------------------------------------------------------------
.env
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Runtime-generated files (recordings, reports, visualizations, etc.)
# These are personal and/or large. We keep the directories via .gitkeep files.
# -----------------------------------------------------------------------------

# User practice recordings + auto-generated visualizations
audio/user_recordings/
!audio/user_recordings/.gitkeep

# Generated evaluation reports
reports/
!reports/.gitkeep

# Synthetic or downloaded reference audio (keep only if you explicitly want to commit one)
# See negation example at the bottom of this file.
audio/references/*.wav
audio/references/*.flac
audio/references/*.mp3
audio/references/*.ogg
audio/references/*.m4a
audio/references/*.aac

# Visualization images generated during practice sessions
**/*_waveform.png
**/*_pitch.png
**/*_energy.png
**/*_spectrogram.png

# Local ML model caches (if someone downloads them inside the project)
models/
whisper_models/
*.bin
*.pt

# Debug / temporary folders
debug/
tmp/
temp/

# Internal task file (not part of the public project)
project-instructions.md

# Leftover directory from previous layout (safe to ignore)
sanskrit_mantra_coach/

# -----------------------------------------------------------------------------
# Optional: Force-include a specific high-quality reference recording
# -----------------------------------------------------------------------------
# If you later want to commit one canonical reference audio file, uncomment:
# !audio/references/gayatri_mantra.wav
